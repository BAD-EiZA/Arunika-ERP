// ─── Tax Indonesia ───────────────────────────────────────

model TaxRegistration {
  id        String    @id @default(cuid())
  companyId String
  npwp      String?
  isPkp     Boolean   @default(false)
  pkpDate   DateTime?
  taxOffice String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model TaxCode {
  id            String       @id @default(cuid())
  companyId     String
  code          String
  name          String
  taxType       TaxType
  direction     TaxDirection
  rate          Decimal      @db.Decimal(8, 4)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  glAccountCode String?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code, effectiveFrom])
  @@index([companyId])
}

model TaxDocument {
  id            String         @id @default(cuid())
  companyId     String
  number        String
  docType       String
  taxType       TaxType
  status        DocumentStatus @default(DRAFT)
  partnerName   String?
  partnerNpwp   String?
  dpp           Decimal        @default(0) @db.Decimal(18, 2)
  taxAmount     Decimal        @default(0) @db.Decimal(18, 2)
  documentDate  DateTime
  taxPeriod     String?
  sourceDocType String?
  sourceDocId   String?
  version       Int            @default(1)
  replacesId    String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, number, version])
  @@index([companyId])
  @@index([taxPeriod])
}

// ─── Supporting ──────────────────────────────────────────

model FileAsset {
  id                 String     @id @default(cuid())
  companyId          String
  uploaderId         String?
  status             FileStatus @default(PENDING)
  access             FileAccess @default(AUTHENTICATED)
  cloudinaryPublicId String?
  cloudinaryAssetId  String?
  resourceType       String?
  format             String?
  mimeType           String?
  size               Int?
  width              Int?
  height             Int?
  originalFilename   String?
  entityType         String?
  entityId           String?
  createdAt          DateTime   @default(now())
  deletedAt          DateTime?

  company  Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploader User?   @relation(fields: [uploaderId], references: [id])

  @@index([companyId])
  @@index([entityType, entityId])
}

model AuditLog {
  id           String   @id @default(cuid())
  companyId    String?
  userId       String?
  action       String
  entityType   String
  entityId     String?
  entityNumber String?
  beforeData   Json?
  afterData    Json?
  metadata     Json?
  ipAddress    String?
  userAgent    String?
  requestId    String?
  createdAt    DateTime @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@index([userId])
}

model Notification {
  id         String    @id @default(cuid())
  companyId  String
  userId     String
  type       String
  title      String
  message    String
  entityType String?
  entityId   String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([companyId])
}

// ─── Manufacturing (Fase 8) ──────────────────────────────

enum ProductionOrderStatus {
  DRAFT
  RELEASED
  IN_PROGRESS
  COMPLETED
  CLOSED
  CANCELLED
}

model WorkCenter {
  id          String   @id @default(cuid())
  companyId   String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  routingSteps   RoutingStep[]
  productionSteps ProductionStep[]

  @@unique([companyId, code])
  @@index([companyId])
}

model BillOfMaterials {
  id               String   @id @default(cuid())
  companyId        String
  code             String
  name             String
  finishedProductId String
  version          Int      @default(1)
  quantity         Decimal  @default(1) @db.Decimal(18, 4)
  isActive         Boolean  @default(true)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  finishedProduct Product          @relation("BomFinished", fields: [finishedProductId], references: [id])
  items           BomItem[]
  productionOrders ProductionOrder[]

  @@unique([companyId, code, version])
  @@index([companyId])
  @@index([finishedProductId])
}

model BomItem {
  id         String  @id @default(cuid())
  bomId      String
  productId  String
  quantity   Decimal @db.Decimal(18, 4)
  scrapPct   Decimal @default(0) @db.Decimal(8, 4)
  notes      String?

  bom     BillOfMaterials @relation(fields: [bomId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])

  @@index([bomId])
  @@index([productId])
}

model Routing {
  id          String   @id @default(cuid())
  companyId   String
  code        String
  name        String
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  steps            RoutingStep[]
  productionOrders ProductionOrder[]

  @@unique([companyId, code, version])
  @@index([companyId])
}

model RoutingStep {
  id           String  @id @default(cuid())
  routingId    String
  workCenterId String
  sequence     Int
  name         String
  setupMinutes Decimal @default(0) @db.Decimal(18, 2)
  runMinutes   Decimal @default(0) @db.Decimal(18, 2)

  routing    Routing    @relation(fields: [routingId], references: [id], onDelete: Cascade)
  workCenter WorkCenter @relation(fields: [workCenterId], references: [id])

  @@index([routingId])
}

model ProductionOrder {
  id                String                @id @default(cuid())
  companyId         String
  number            String
  status            ProductionOrderStatus @default(DRAFT)
  finishedProductId String
  bomId             String?
  routingId         String?
  warehouseId       String?
  plannedQty        Decimal               @db.Decimal(18, 4)
  completedQty      Decimal               @default(0) @db.Decimal(18, 4)
  plannedStart      DateTime?
  plannedEnd        DateTime?
  releasedAt        DateTime?
  completedAt       DateTime?
  closedAt          DateTime?
  materialCost      Decimal               @default(0) @db.Decimal(18, 2)
  laborCost         Decimal               @default(0) @db.Decimal(18, 2)
  overheadCost      Decimal               @default(0) @db.Decimal(18, 2)
  totalCost         Decimal               @default(0) @db.Decimal(18, 2)
  unitCost          Decimal               @default(0) @db.Decimal(18, 4)
  notes             String?
  createdById       String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  company         Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  finishedProduct Product              @relation("ProductionFinished", fields: [finishedProductId], references: [id])
  bom             BillOfMaterials?     @relation(fields: [bomId], references: [id])
  routing         Routing?             @relation(fields: [routingId], references: [id])
  materials       ProductionMaterial[]
  steps           ProductionStep[]
  costEntries     ProductionCostEntry[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([finishedProductId])
}

model ProductionMaterial {
  id                String  @id @default(cuid())
  productionOrderId String
  productId         String
  plannedQty        Decimal @db.Decimal(18, 4)
  issuedQty         Decimal @default(0) @db.Decimal(18, 4)
  unitCost          Decimal @default(0) @db.Decimal(18, 4)
  totalCost         Decimal @default(0) @db.Decimal(18, 2)

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@index([productionOrderId])
  @@index([productId])
}

model ProductionStep {
  id                String  @id @default(cuid())
  productionOrderId String
  workCenterId      String?
  sequence          Int
  name              String
  plannedMinutes    Decimal @default(0) @db.Decimal(18, 2)
  reportedMinutes   Decimal @default(0) @db.Decimal(18, 2)
  laborRate         Decimal @default(0) @db.Decimal(18, 2)
  overheadRate      Decimal @default(0) @db.Decimal(18, 2)
  laborCost         Decimal @default(0) @db.Decimal(18, 2)
  overheadCost      Decimal @default(0) @db.Decimal(18, 2)
  isDone            Boolean @default(false)

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)
  workCenter      WorkCenter?     @relation(fields: [workCenterId], references: [id])

  @@index([productionOrderId])
}

model ProductionCostEntry {
  id                String   @id @default(cuid())
  productionOrderId String
  costType          String
  amount            Decimal  @db.Decimal(18, 2)
  quantity          Decimal  @default(0) @db.Decimal(18, 4)
  reference         String?
  notes             String?
  createdAt         DateTime @default(now())

  productionOrder ProductionOrder @relation(fields: [productionOrderId], references: [id], onDelete: Cascade)

  @@index([productionOrderId])
  @@index([costType])
}

// ─── Planning / MRP (Fase 9) ─────────────────────────────

model MrpRun {
  id          String   @id @default(cuid())
  companyId   String
  number      String
  status      DocumentStatus @default(DRAFT)
  horizonDays Int      @default(30)
  notes       String?
  ranAt       DateTime @default(now())
  createdById String?
  createdAt   DateTime @default(now())

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   MrpSuggestion[]

  @@unique([companyId, number])
  @@index([companyId])
}

model MrpSuggestion {
  id            String  @id @default(cuid())
  mrpRunId      String
  productId     String
  suggestionType String
  quantity      Decimal @db.Decimal(18, 4)
  onHand        Decimal @default(0) @db.Decimal(18, 4)
  demand        Decimal @default(0) @db.Decimal(18, 4)
  supply        Decimal @default(0) @db.Decimal(18, 4)
  dueDate       DateTime?
  sourceRef     String?
  isConverted   Boolean @default(false)

  mrpRun MrpRun @relation(fields: [mrpRunId], references: [id], onDelete: Cascade)

  @@index([mrpRunId])
  @@index([productId])
}

// ─── HR (Fase 10) ────────────────────────────────────────

model Employee {
  id           String    @id @default(cuid())
  companyId    String
  code         String
  name         String
  email        String?
  phone        String?
  departmentId String?
  position     String?
  joinDate     DateTime?
  endDate      DateTime?
  baseSalary   Decimal   @default(0) @db.Decimal(18, 2)
  bankAccount  String?
  isActive     Boolean   @default(true)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendance  AttendanceRecord[]
  leaveRequests LeaveRequest[]
  payrollLines PayrollLine[]
  timesheets  Timesheet[]

  @@unique([companyId, code])
  @@index([companyId])
}

model AttendanceRecord {
  id         String   @id @default(cuid())
  companyId  String
  employeeId String
  workDate   DateTime
  checkIn    DateTime?
  checkOut   DateTime?
  status     String   @default("PRESENT")
  notes      String?
  createdAt  DateTime @default(now())

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, workDate])
  @@index([companyId])
}

model LeaveRequest {
  id         String         @id @default(cuid())
  companyId  String
  employeeId String
  leaveType  String
  startDate  DateTime
  endDate    DateTime
  days       Decimal        @db.Decimal(8, 2)
  status     DocumentStatus @default(DRAFT)
  reason     String?
  approvedAt DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
}

// ─── Payroll (Fase 11) ───────────────────────────────────

model PayrollRun {
  id          String         @id @default(cuid())
  companyId   String
  number      String
  periodStart DateTime
  periodEnd   DateTime
  status      DocumentStatus @default(DRAFT)
  totalGross  Decimal        @default(0) @db.Decimal(18, 2)
  totalDeduction Decimal     @default(0) @db.Decimal(18, 2)
  totalNet    Decimal        @default(0) @db.Decimal(18, 2)
  postedAt    DateTime?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   PayrollLine[]

  @@unique([companyId, number])
  @@index([companyId])
}

model PayrollLine {
  id           String  @id @default(cuid())
  payrollRunId String
  employeeId   String
  baseSalary   Decimal @db.Decimal(18, 2)
  allowances   Decimal @default(0) @db.Decimal(18, 2)
  overtime     Decimal @default(0) @db.Decimal(18, 2)
  deductions   Decimal @default(0) @db.Decimal(18, 2)
  taxAmount    Decimal @default(0) @db.Decimal(18, 2)
  bpjsAmount   Decimal @default(0) @db.Decimal(18, 2)
  grossPay     Decimal @db.Decimal(18, 2)
  netPay       Decimal @db.Decimal(18, 2)

  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id])

  @@index([payrollRunId])
  @@index([employeeId])
}

// ─── Returns & Claims (Fase 12) ──────────────────────────

model SalesReturn {
  id              String         @id @default(cuid())
  companyId       String
  number          String
  customerId      String
  salesInvoiceId  String?
  warehouseId     String?
  status          DocumentStatus @default(DRAFT)
  reason          String?
  subtotal        Decimal        @default(0) @db.Decimal(18, 2)
  taxAmount       Decimal        @default(0) @db.Decimal(18, 2)
  total           Decimal        @default(0) @db.Decimal(18, 2)
  postedAt        DateTime?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   SalesReturnItem[]

  @@unique([companyId, number])
  @@index([companyId])
}

model SalesReturnItem {
  id            String  @id @default(cuid())
  salesReturnId String
  productId     String
  quantity      Decimal @db.Decimal(18, 4)
  unitPrice     Decimal @db.Decimal(18, 4)
  total         Decimal @db.Decimal(18, 2)

  salesReturn SalesReturn @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)

  @@index([salesReturnId])
}

model PurchaseReturn {
  id              String         @id @default(cuid())
  companyId       String
  number          String
  supplierId      String
  purchaseOrderId String?
  warehouseId     String?
  status          DocumentStatus @default(DRAFT)
  reason          String?
  subtotal        Decimal        @default(0) @db.Decimal(18, 2)
  total           Decimal        @default(0) @db.Decimal(18, 2)
  postedAt        DateTime?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   PurchaseReturnItem[]

  @@unique([companyId, number])
  @@index([companyId])
}

model PurchaseReturnItem {
  id               String  @id @default(cuid())
  purchaseReturnId String
  productId        String
  quantity         Decimal @db.Decimal(18, 4)
  unitCost         Decimal @db.Decimal(18, 4)
  total            Decimal @db.Decimal(18, 2)

  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)

  @@index([purchaseReturnId])
}

model Claim {
  id          String         @id @default(cuid())
  companyId   String
  number      String
  claimType   String
  partnerName String?
  status      DocumentStatus @default(DRAFT)
  amount      Decimal        @default(0) @db.Decimal(18, 2)
  reason      String?
  resolution  String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, number])
  @@index([companyId])
}

// ─── Project (Fase 13) ───────────────────────────────────

model Project {
  id          String         @id @default(cuid())
  companyId   String
  code        String
  name        String
  customerId  String?
  status      DocumentStatus @default(DRAFT)
  startDate   DateTime?
  endDate     DateTime?
  budgetAmount Decimal       @default(0) @db.Decimal(18, 2)
  actualCost  Decimal        @default(0) @db.Decimal(18, 2)
  billedAmount Decimal       @default(0) @db.Decimal(18, 2)
  managerName String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks      ProjectTask[]
  timesheets Timesheet[]
  expenses   ProjectExpense[]

  @@unique([companyId, code])
  @@index([companyId])
}

model ProjectTask {
  id          String         @id @default(cuid())
  projectId   String
  code        String
  name        String
  status      DocumentStatus @default(DRAFT)
  plannedHours Decimal       @default(0) @db.Decimal(18, 2)
  actualHours  Decimal       @default(0) @db.Decimal(18, 2)
  dueDate     DateTime?

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  timesheets Timesheet[]

  @@index([projectId])
}

model Timesheet {
  id         String         @id @default(cuid())
  companyId  String?
  projectId  String
  taskId     String?
  employeeId String?
  workDate   DateTime
  hours      Decimal        @db.Decimal(18, 2)
  status     DocumentStatus @default(DRAFT)
  notes      String?
  createdAt  DateTime       @default(now())

  project  Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task     ProjectTask? @relation(fields: [taskId], references: [id])
  employee Employee?    @relation(fields: [employeeId], references: [id])

  @@index([projectId])
  @@index([employeeId])
}

model ProjectExpense {
  id          String         @id @default(cuid())
  projectId   String
  description String
  amount      Decimal        @db.Decimal(18, 2)
  expenseDate DateTime       @default(now())
  status      DocumentStatus @default(POSTED)
  createdAt   DateTime       @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ─── Credit/Debit Notes ──────────────────────────────────

model CreditNote {
  id             String         @id @default(cuid())
  companyId      String
  number         String
  customerId     String?
  salesInvoiceId String?
  salesReturnId  String?
  status         DocumentStatus @default(DRAFT)
  reason         String?
  subtotal       Decimal        @default(0) @db.Decimal(18, 2)
  taxAmount      Decimal        @default(0) @db.Decimal(18, 2)
  total          Decimal        @default(0) @db.Decimal(18, 2)
  postedAt       DateTime?
  createdById    String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  company Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   CreditNoteItem[]

  @@unique([companyId, number])
  @@index([companyId])
}

model CreditNoteItem {
  id           String  @id @default(cuid())
  creditNoteId String
  productId    String?
  description  String
  quantity     Decimal @db.Decimal(18, 4)
  unitPrice    Decimal @db.Decimal(18, 4)
  total        Decimal @db.Decimal(18, 2)

  creditNote CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)

  @@index([creditNoteId])
}

model DebitNote {
  id              String         @id @default(cuid())
  companyId       String
  number          String
  supplierId      String?
  supplierBillId  String?
  purchaseReturnId String?
  status          DocumentStatus @default(DRAFT)
  reason          String?
  subtotal        Decimal        @default(0) @db.Decimal(18, 2)
  taxAmount       Decimal        @default(0) @db.Decimal(18, 2)
  total           Decimal        @default(0) @db.Decimal(18, 2)
  postedAt        DateTime?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items   DebitNoteItem[]

  @@unique([companyId, number])
  @@index([companyId])
}

model DebitNoteItem {
  id          String  @id @default(cuid())
  debitNoteId String
  productId   String?
  description String
  quantity    Decimal @db.Decimal(18, 4)
  unitPrice   Decimal @db.Decimal(18, 4)
  total       Decimal @db.Decimal(18, 2)

  debitNote DebitNote @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)

  @@index([debitNoteId])
}

// ─── Email Outbox ────────────────────────────────────────

model EmailOutbox {
  id          String    @id @default(cuid())
  companyId   String?
  toEmail     String
  subject     String
  body        String
  status      String    @default("PENDING")
  entityType  String?
  entityId    String?
  error       String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([companyId])
}

// ─── CRM ─────────────────────────────────────────────────

model CrmLead {
  id          String   @id @default(cuid())
  companyId   String
  name        String
  email       String?
  phone       String?
  companyName String?
  source      String?
  status      String   @default("NEW")
  notes       String?
  ownerName   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company       Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  opportunities CrmOpportunity[]

  @@index([companyId])
  @@index([status])
}

model CrmOpportunity {
  id          String         @id @default(cuid())
  companyId   String
  leadId      String?
  customerId  String?
  title       String
  stage       String         @default("QUALIFICATION")
  amount      Decimal        @default(0) @db.Decimal(18, 2)
  probability Int            @default(10)
  expectedClose DateTime?
  status      DocumentStatus @default(OPEN)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lead    CrmLead? @relation(fields: [leadId], references: [id])

  @@index([companyId])
  @@index([stage])
}

// ─── POS ─────────────────────────────────────────────────

model PosSession {
  id          String    @id @default(cuid())
  companyId   String
  warehouseId String?
  branchId    String?
  cashierName String?
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  openingCash Decimal   @default(0) @db.Decimal(18, 2)
  closingCash Decimal?  @db.Decimal(18, 2)
  status      String    @default("OPEN")

  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders  PosOrder[]

  @@index([companyId])
  @@index([status])
}

model PosOrder {
  id          String         @id @default(cuid())
  companyId   String
  sessionId   String
  number      String
  status      DocumentStatus @default(POSTED)
  subtotal    Decimal        @default(0) @db.Decimal(18, 2)
  taxAmount   Decimal        @default(0) @db.Decimal(18, 2)
  total       Decimal        @default(0) @db.Decimal(18, 2)
  paidAmount  Decimal        @default(0) @db.Decimal(18, 2)
  paymentMethod String       @default("CASH")
  warehouseId String?
  createdById String?
  createdAt   DateTime       @default(now())

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  session PosSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  items   PosOrderItem[]

  @@unique([companyId, number])
  @@index([companyId])
  @@index([sessionId])
}

model PosOrderItem {
  id         String  @id @default(cuid())
  posOrderId String
  productId  String
  quantity   Decimal @db.Decimal(18, 4)
  unitPrice  Decimal @db.Decimal(18, 4)
  total      Decimal @db.Decimal(18, 2)

  posOrder PosOrder @relation(fields: [posOrderId], references: [id], onDelete: Cascade)

  @@index([posOrderId])
}

// ─── Portal tokens ───────────────────────────────────────

model PortalToken {
  id          String    @id @default(cuid())
  companyId   String
  portalType  String
  partnerId   String
  partnerEmail String
  token       String    @unique @default(cuid())
  expiresAt   DateTime
  lastAccessAt DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, portalType])
  @@index([token])
}

// ─── WMS advanced ────────────────────────────────────────

model WarehouseBin {
  id          String   @id @default(cuid())
  companyId   String
  warehouseId String
  code        String
  name        String
  aisle       String?
  rack        String?
  level       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  balances StockBinBalance[]

  @@unique([warehouseId, code])
  @@index([companyId])
}

model StockBinBalance {
  id          String   @id @default(cuid())
  companyId   String
  warehouseId String
  binId       String
  productId   String
  quantity    Decimal  @default(0) @db.Decimal(18, 4)
  updatedAt   DateTime @updatedAt

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bin     WarehouseBin @relation(fields: [binId], references: [id], onDelete: Cascade)

  @@unique([binId, productId])
  @@index([companyId, warehouseId])
  @@index([productId])
}

// ─── AI insights ─────────────────────────────────────────

model AiInsight {
  id          String   @id @default(cuid())
  companyId   String
  insightType String
  title       String
  summary     String
  severity    String   @default("info")
  payload     Json?
  model       String?
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, insightType])
  @@index([createdAt])
}

// ─── Recurring / Bank feed ───────────────────────────────

model RecurringJournal {
  id          String    @id @default(cuid())
  companyId   String
  name        String
  description String?
  frequency   String    @default("MONTHLY")
  nextRunAt   DateTime
  endDate     DateTime?
  isActive    Boolean   @default(true)
  currency    String    @default("IDR")
  exchangeRate Decimal  @default(1) @db.Decimal(18, 8)
  lines       Json
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, nextRunAt])
}

model RecurringInvoice {
  id              String    @id @default(cuid())
  companyId       String
  customerId      String
  name            String
  frequency       String    @default("MONTHLY")
  nextRunAt       DateTime
  endDate         DateTime?
  isActive        Boolean   @default(true)
  paymentTermDays Int       @default(30)
  currency        String    @default("IDR")
  exchangeRate    Decimal   @default(1) @db.Decimal(18, 8)
  taxRate         Decimal   @default(0) @db.Decimal(8, 4)
  lines           Json
  lastRunAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company  Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([companyId, nextRunAt])
}

model BankFeed {
  id            String    @id @default(cuid())
  companyId     String
  bankAccountId String
  provider      String    @default("CSV")
  externalRef   String?
  lastSyncAt    DateTime?
  isActive      Boolean   @default(true)
  meta          Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  @@unique([companyId, bankAccountId, provider])
  @@index([companyId])
}



