  id           String             @id @default(cuid())
  fiscalYearId String
  name         String
  startDate    DateTime
  endDate      DateTime
  status       FiscalPeriodStatus @default(OPEN)

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)
