generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum MembershipStatus {
  INVITED
  ACTIVE
  DISABLED
}

enum ProductType {
  STOCK
  NON_STOCK
  SERVICE
}

enum WarehouseType {
  MAIN
  TRANSIT
  RETURN
  DAMAGED
  VIRTUAL
}

enum StockMovementType {
  PURCHASE_RECEIPT
  SALES_DELIVERY
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  SALES_RETURN
  PURCHASE_RETURN
  OPENING_BALANCE
  OPNAME_CORRECTION
  PRODUCTION_ISSUE
  PRODUCTION_RECEIPT
}

enum DocumentStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  PARTIALLY_DELIVERED
  DELIVERED
  PARTIALLY_INVOICED
  INVOICED
  PARTIALLY_PAID
  PAID
  OVERDUE
  OPEN
  CLOSED
  CANCELLED
  VOID
  POSTED
  IN_TRANSIT
  COUNTING
  REVIEW
  ISSUED
  REVERSED
}

enum FileStatus {
  PENDING
  READY
  FAILED
  DELETED
}

enum FileAccess {
  PUBLIC
  AUTHENTICATED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  COGS
  EXPENSE
  OTHER_INCOME
  OTHER_EXPENSE
}

enum JournalStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  POSTED
  REVERSED
  CANCELLED
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum TaxType {
  PPN
  PPH21
  PPH22
  PPH23
  PPH4_2
  PPH26
  OTHER
}

enum TaxDirection {
  INPUT
  OUTPUT
  WITHHOLDING
}

// ─── Identity & Tenancy ──────────────────────────────────

model User {
  id          String    @id @default(cuid())
  kindeUserId String?   @unique
  email       String    @unique
  name        String?
  avatarUrl   String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships     Membership[]
  invitationsSent Invitation[]   @relation("InvitedBy")
  auditLogs       AuditLog[]
  notifications   Notification[]
  filesUploaded   FileAsset[]
}

model Company {
  id                 String   @id @default(cuid())
  code               String   @unique
  name               String
  legalName          String?
  email              String?
  phone              String?
  taxNumber          String?
  address            String?
  city               String?
  province           String?
  country            String   @default("ID")
  postalCode         String?
  timezone           String   @default("Asia/Jakarta")
  currency           String   @default("IDR")
  language           String   @default("id")
  logoUrl            String?
  isActive           Boolean  @default(true)
  allowNegativeStock Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  memberships       Membership[]
  roles             Role[]
  branches          Branch[]
  warehouses        Warehouse[]
  invitations       Invitation[]
  settings          CompanySetting?
  documentSequences DocumentSequence[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  products          Product[]
  categories        ProductCategory[]
  units             Unit[]
  customers         Customer[]
  suppliers         Supplier[]
  stockBalances     StockBalance[]
  stockMovements    StockMovement[]
  stockReservations StockReservation[]
  stockTransfers    StockTransfer[]
  stockAdjustments  StockAdjustment[]
  stockOpnames      StockOpname[]
  purchaseOrders    PurchaseOrder[]
  goodsReceipts     GoodsReceipt[]
  supplierBills     SupplierBill[]
  supplierPayments  SupplierPayment[]
  salesOrders       SalesOrder[]
  deliveryOrders    DeliveryOrder[]
  salesInvoices     SalesInvoice[]
  customerPayments  CustomerPayment[]
  fileAssets        FileAsset[]
  approvalMatrices  ApprovalMatrix[]
  accounts          Account[]
  fiscalYears       FiscalYear[]
  journals          Journal[]
  postingRules      PostingRule[]
  bankAccounts      BankAccount[]
  budgets           Budget[]
  fixedAssets       FixedAsset[]
  taxRegistrations  TaxRegistration[]
  taxCodes          TaxCode[]
  taxDocuments      TaxDocument[]
  purchaseRequests  PurchaseRequest[]
  rfqs              RequestForQuotation[]
  purchaseContracts PurchaseContract[]
  threeWayMatches   ThreeWayMatch[]
  vendorEvaluations VendorEvaluation[]
  departments       Department[]
  costCenters       CostCenter[]
  vendorQuotations  VendorQuotation[]
  workCenters       WorkCenter[]
  boms              BillOfMaterials[]
  routings          Routing[]
  productionOrders  ProductionOrder[]
  mrpRuns           MrpRun[]
  employees         Employee[]
  attendanceRecords AttendanceRecord[]
  leaveRequests     LeaveRequest[]
  payrollRuns       PayrollRun[]
  salesReturns      SalesReturn[]
  purchaseReturns   PurchaseReturn[]
  claims            Claim[]
  projects          Project[]
  creditNotes       CreditNote[]
  debitNotes        DebitNote[]
  emailOutbox       EmailOutbox[]
  crmLeads          CrmLead[]
  crmOpportunities CrmOpportunity[]
  posSessions       PosSession[]
  posOrders         PosOrder[]
  portalTokens      PortalToken[]
  warehouseBins     WarehouseBin[]
  stockBinBalances  StockBinBalance[]
  aiInsights        AiInsight[]
  expenses          ExpenseClaim[]
  recurringJournals RecurringJournal[]
  recurringInvoices RecurringInvoice[]
  bankFeeds         BankFeed[]
}

model Membership {
  id            String           @id @default(cuid())
  companyId     String
  userId        String
  roleId        String
  status        MembershipStatus @default(ACTIVE)
  approvalLimit Decimal?         @db.Decimal(18, 2)
  joinedAt      DateTime         @default(now())
  invitedAt     DateTime?
  lastActiveAt  DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role    Role    @relation(fields: [roleId], references: [id])

  branchAccess    MembershipBranch[]
  warehouseAccess MembershipWarehouse[]

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId])
}

model Role {
  id          String   @id @default(cuid())
  companyId   String?
  code        String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company?         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  memberships Membership[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Permission {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?
  module      String

  roles RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model MembershipBranch {
  membershipId String
  branchId     String

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  branch     Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([membershipId, branchId])
}

model MembershipWarehouse {
  membershipId String
  warehouseId  String

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  warehouse  Warehouse  @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@id([membershipId, warehouseId])
}

model Invitation {
  id          String           @id @default(cuid())
  companyId   String
  email       String
  roleId      String
  status      MembershipStatus @default(INVITED)
  token       String           @unique @default(cuid())
  expiresAt   DateTime
  invitedById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy User?   @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([companyId, email])
}

model CompanySetting {
  id                  String  @id @default(cuid())
  companyId           String  @unique
  defaultBranchId     String?
  defaultWarehouseId  String?
  invoiceFromDelivery Boolean @default(true)
  reserveOnSoApprove  Boolean @default(true)
  inventoryValuation  String  @default("MOVING_AVERAGE")
  poApprovalRequired  Boolean @default(true)
  soApprovalRequired  Boolean @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model DocumentSequence {
  id        String  @id @default(cuid())
  companyId String
  docType   String
  branchId  String?
  prefix    String
  pattern   String  @default("{PREFIX}/{YYYY}/{SEQUENCE}")
  lastValue Int     @default(0)
  padLength Int     @default(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, docType, branchId])
  @@index([companyId])
}

model Branch {
  id        String   @id @default(cuid())
  companyId String
  code      String
  name      String
  address   String?
  city      String?
  province  String?
  phone     String?
  email     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company          Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouses       Warehouse[]
  membershipAccess MembershipBranch[]
  purchaseOrders   PurchaseOrder[]
  salesOrders      SalesOrder[]
  purchaseRequests PurchaseRequest[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Warehouse {
  id        String        @id @default(cuid())
  companyId String
  branchId  String
  code      String
  name      String
  address   String?
  type      WarehouseType @default(MAIN)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  company          Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch           Branch                @relation(fields: [branchId], references: [id])
  membershipAccess MembershipWarehouse[]
  stockBalances    StockBalance[]
  stockMovements   StockMovement[]
  transfersFrom    StockTransfer[]       @relation("TransferFrom")
  transfersTo      StockTransfer[]       @relation("TransferTo")
  adjustments      StockAdjustment[]
  opnames          StockOpname[]
  purchaseOrders   PurchaseOrder[]
  goodsReceipts    GoodsReceipt[]
  salesOrders      SalesOrder[]
  deliveryOrders   DeliveryOrder[]

  @@unique([companyId, code])
  @@index([companyId])
  @@index([branchId])
}

model Department {
  id        String   @id @default(cuid())
  companyId String
  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, code])
}

model CostCenter {
  id        String   @id @default(cuid())
  companyId String
  code      String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  journalLines JournalLine[]

  @@unique([companyId, code])
}

model ApprovalMatrix {
  id        String   @id @default(cuid())
  companyId String
  docType   String
  minAmount Decimal  @default(0) @db.Decimal(18, 2)
  maxAmount Decimal? @db.Decimal(18, 2)
  roleCode  String
  stepOrder Int      @default(1)
  isActive  Boolean  @default(true)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, docType])
}

// ─── Master Data ─────────────────────────────────────────

model Unit {
  id        String   @id @default(cuid())
  companyId String
  name      String
  symbol    String
  precision Int      @default(2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([companyId, symbol])
  @@index([companyId])
}

model ProductCategory {
  id          String   @id @default(cuid())
  companyId   String
  code        String
  name        String
  parentId    String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent   ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryTree")
  products Product[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Product {
  id            String      @id @default(cuid())
  companyId     String
  sku           String
  barcode       String?
  name          String
  description   String?
  categoryId    String?
  unitId        String
  type          ProductType @default(STOCK)
  purchasePrice Decimal     @default(0) @db.Decimal(18, 4)
  salePrice     Decimal     @default(0) @db.Decimal(18, 4)
  minStock      Decimal     @default(0) @db.Decimal(18, 4)
  maxStock      Decimal?    @db.Decimal(18, 4)
  weight        Decimal?    @db.Decimal(18, 4)
  imageUrl      String?
  isActive      Boolean     @default(true)
  isArchived    Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  company           Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category          ProductCategory?       @relation(fields: [categoryId], references: [id])
  unit              Unit                   @relation(fields: [unitId], references: [id])
  stockBalances     StockBalance[]
  stockMovements    StockMovement[]
  stockReservations StockReservation[]
  transferItems     StockTransferItem[]
  adjustmentItems   StockAdjustmentItem[]
  opnameItems       StockOpnameItem[]
  poItems           PurchaseOrderItem[]
  grItems           GoodsReceiptItem[]
  soItems           SalesOrderItem[]
  doItems           DeliveryOrderItem[]
  invoiceItems      SalesInvoiceItem[]
  billItems         SupplierBillItem[]
  prItems           PurchaseRequestItem[]
  contractItems     PurchaseContractItem[]
  bomsAsFinished    BillOfMaterials[]      @relation("BomFinished")
  bomComponents     BomItem[]
  productionOrders  ProductionOrder[]      @relation("ProductionFinished")

  @@unique([companyId, sku])
  @@index([companyId])
  @@index([companyId, name])
}

model Customer {
  id              String   @id @default(cuid())
  companyId       String
  code            String
  name            String
  companyName     String?
  email           String?
  phone           String?
  taxNumber       String?
  billingAddress  String?
  shippingAddress String?
  city            String?
  province        String?
  country         String   @default("ID")
  postalCode      String?
  paymentTermDays Int      @default(30)
  creditLimit     Decimal? @db.Decimal(18, 2)
  notes           String?
  isActive        Boolean  @default(true)
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  salesOrders       SalesOrder[]
  deliveryOrders    DeliveryOrder[]
  salesInvoices     SalesInvoice[]
  customerPayments  CustomerPayment[]
  recurringInvoices RecurringInvoice[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Supplier {
  id              String   @id @default(cuid())
  companyId       String
  code            String
  name            String
  legalName       String?
  email           String?
  phone           String?
  taxNumber       String?
  address         String?
  paymentTermDays Int      @default(30)
  currency        String   @default("IDR")
  bankAccount     String?
  bankName        String?
  contactName     String?
  notes           String?
  isActive        Boolean  @default(true)
  isArchived      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseOrders    PurchaseOrder[]
  goodsReceipts     GoodsReceipt[]
  supplierBills     SupplierBill[]
  supplierPayments  SupplierPayment[]
  rfqVendors        RfqVendor[]
  vendorQuotations  VendorQuotation[]
  purchaseContracts PurchaseContract[]
  vendorEvaluations VendorEvaluation[]

  @@unique([companyId, code])
  @@index([companyId])
}

// ─── Inventory ───────────────────────────────────────────

model StockBalance {
  id               String   @id @default(cuid())
  companyId        String
  warehouseId      String
  productId        String
  quantityOnHand   Decimal  @default(0) @db.Decimal(18, 4)
  quantityReserved Decimal  @default(0) @db.Decimal(18, 4)
  averageCost      Decimal  @default(0) @db.Decimal(18, 4)
  updatedAt        DateTime @updatedAt

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([warehouseId, productId])
  @@index([companyId])
  @@index([productId])
}

model StockMovement {
  id              String            @id @default(cuid())
  companyId       String
  warehouseId     String
  productId       String
  type            StockMovementType
  quantity        Decimal           @db.Decimal(18, 4)
  unitCost        Decimal           @default(0) @db.Decimal(18, 4)
  totalCost       Decimal           @default(0) @db.Decimal(18, 4)
  referenceType   String?
  referenceId     String?
  referenceNumber String?
  notes           String?
  idempotencyKey  String?
  createdById     String?
  postedAt        DateTime          @default(now())
  createdAt       DateTime          @default(now())

  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  product   Product   @relation(fields: [productId], references: [id])

  @@unique([companyId, idempotencyKey])
  @@index([companyId, productId])
  @@index([companyId, warehouseId])
  @@index([referenceType, referenceId])
}

model StockReservation {
  id           String    @id @default(cuid())
  companyId    String
  warehouseId  String
  productId    String
  salesOrderId String?
  quantity     Decimal   @db.Decimal(18, 4)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  releasedAt   DateTime?

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product    Product     @relation(fields: [productId], references: [id])
  salesOrder SalesOrder? @relation(fields: [salesOrderId], references: [id])

  @@index([companyId, productId])
  @@index([salesOrderId])
}

model StockTransfer {
  id              String         @id @default(cuid())
  companyId       String
  number          String
  fromWarehouseId String
  toWarehouseId   String
  status          DocumentStatus @default(DRAFT)
  notes           String?
  transferredAt   DateTime?
  receivedAt      DateTime?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromWarehouse Warehouse           @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse           @relation("TransferTo", fields: [toWarehouseId], references: [id])
  items         StockTransferItem[]

  @@unique([companyId, number])
  @@index([companyId])
}

model StockTransferItem {
  id          String  @id @default(cuid())
  transferId  String
  productId   String
  quantity    Decimal @db.Decimal(18, 4)
  receivedQty Decimal @default(0) @db.Decimal(18, 4)

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  product  Product       @relation(fields: [productId], references: [id])

  @@index([transferId])
}

model StockAdjustment {
  id          String         @id @default(cuid())
  companyId   String
  warehouseId String
  number      String
  status      DocumentStatus @default(DRAFT)
  reason      String
  notes       String?
  postedAt    DateTime?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company   Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse             @relation(fields: [warehouseId], references: [id])
  items     StockAdjustmentItem[]

  @@unique([companyId, number])
  @@index([companyId])
}

model StockAdjustmentItem {
  id             String  @id @default(cuid())
  adjustmentId   String
  productId      String
  quantityBefore Decimal @db.Decimal(18, 4)
  quantityDelta  Decimal @db.Decimal(18, 4)
  quantityAfter  Decimal @db.Decimal(18, 4)

  adjustment StockAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  product    Product         @relation(fields: [productId], references: [id])

  @@index([adjustmentId])
}

model StockOpname {
  id          String         @id @default(cuid())
  companyId   String
  warehouseId String
  number      String
  status      DocumentStatus @default(DRAFT)
  notes       String?
  postedAt    DateTime?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse         @relation(fields: [warehouseId], references: [id])
  items     StockOpnameItem[]

  @@unique([companyId, number])
  @@index([companyId])
}

model StockOpnameItem {
  id            String   @id @default(cuid())
  opnameId      String
  productId     String
  systemQty     Decimal  @db.Decimal(18, 4)
  countedQty    Decimal? @db.Decimal(18, 4)
  differenceQty Decimal? @db.Decimal(18, 4)

  opname  StockOpname @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  product Product     @relation(fields: [productId], references: [id])

  @@index([opnameId])
}

// ─── Procurement (Core + Advanced) ───────────────────────

model PurchaseRequest {
  id            String         @id @default(cuid())
  companyId     String
  branchId      String?
  number        String
  status        DocumentStatus @default(DRAFT)
  neededDate    DateTime?
  notes         String?
  requestedById String?
  approvedById  String?
  approvedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch  Branch?               @relation(fields: [branchId], references: [id])
  items   PurchaseRequestItem[]
  rfqs    RequestForQuotation[]

  @@unique([companyId, number])
  @@index([companyId])
}

model PurchaseRequestItem {
  id        String  @id @default(cuid())
  requestId String
  productId String
  quantity  Decimal @db.Decimal(18, 4)
  notes     String?

  request PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id])

  @@index([requestId])
}

model RequestForQuotation {
  id                String         @id @default(cuid())
  companyId         String
  purchaseRequestId String?
  number            String
  status            DocumentStatus @default(DRAFT)
  dueDate           DateTime?
  notes             String?
  awardedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  company         Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  purchaseRequest PurchaseRequest?  @relation(fields: [purchaseRequestId], references: [id])
  vendors         RfqVendor[]
  quotations      VendorQuotation[]

  @@unique([companyId, number])
  @@index([companyId])
}

model RfqVendor {
  id         String @id @default(cuid())
  rfqId      String
  supplierId String

  rfq      RequestForQuotation @relation(fields: [rfqId], references: [id], onDelete: Cascade)
  supplier Supplier            @relation(fields: [supplierId], references: [id])

  @@unique([rfqId, supplierId])
}

model VendorQuotation {
  id         String         @id @default(cuid())
  companyId  String
  rfqId      String
  supplierId String
  number     String?
  status     DocumentStatus @default(DRAFT)
  validUntil DateTime?
  subtotal   Decimal        @default(0) @db.Decimal(18, 2)
  taxAmount  Decimal        @default(0) @db.Decimal(18, 2)
